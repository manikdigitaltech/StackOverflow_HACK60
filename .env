# Copy this file to .env and adjust as needed.
# Nested settings use double-underscore: SECTION__FIELD

# --- MySQL (Docker, local) ---
DB__HOST=localhost
DB__PORT=3306
DB__USER=root
DB__PASSWORD=default
DB__DATABASE=doc_stuff

# --- LangGraph checkpoint (crash-safe pause/resume) ---
CHECKPOINT__BACKEND=sqlite
CHECKPOINT__SQLITE_PATH=./data/langgraph_checkpoints.db

# --- LLM (Ollama, already installed per your setup) ---
LLM__PROVIDER=llama3.2:latest 
LLM__BASE_URL=http://localhost:11434
LLM__TEMPERATURE=0.2
LLM__MAX_TOKENS=4096
LLM__REQUEST_TIMEOUT_SECONDS=120
LLM__CONTEXT_WINDOW=8192

# --- Parsing safety valves ---
PARSING__MAX_PAGES_HARD_CAP=60
PARSING__PROMPT_TOKEN_BUDGET=6000

# --- Vision (optional, off by default) ---
VISION__ENABLED=false

# --- Embeddings ---
EMBEDDINGS__PROVIDER=bge-large-en-v1.5
EMBEDDINGS__DEVICE=cpu

# --- FAISS ---
FAISS__INDEX_PATH=./data/faiss_index
FAISS__TOP_K=5
FAISS__INDEX_TYPE=Flat

# --- Reflection loop ---
REFLECTION__MAX_REVISION_PASSES=1

# --- Ingestion (PeerRead mandatory, arXiv/Semantic Scholar optional) ---
INGESTION__PEERREAD_DATA_PATH=./data/peerread_raw
INGESTION__MAX_PEERREAD_PAPERS=30
INGESTION__ENABLE_ARXIV=false
INGESTION__ENABLE_SEMANTIC_SCHOLAR=false

LOG_LEVEL=INFO
