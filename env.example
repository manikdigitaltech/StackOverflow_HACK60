# Copy this file to .env and adjust as needed.
# Nested settings use double-underscore: SECTION__FIELD

# --- MySQL (Docker, local) ---
DB__HOST=localhost
DB__PORT=3307
DB__USER=reviewer_app
DB__PASSWORD=changeme
DB__DATABASE=paper_reviewer

# --- LangGraph checkpoint (crash-safe pause/resume) ---
CHECKPOINT__BACKEND=sqlite
CHECKPOINT__SQLITE_PATH=./data/langgraph_checkpoints.db

# --- LLM (Ollama, already installed per your setup) ---
LLM__PROVIDER=qwen2.5-7b
LLM__BASE_URL=http://localhost:11434
LLM__TEMPERATURE=0.2
LLM__MAX_TOKENS=4096
LLM__REQUEST_TIMEOUT_SECONDS=120
LLM__CONTEXT_WINDOW=8192

# --- Parsing safety valves ---
PARSING__MAX_PAGES_HARD_CAP=60
PARSING__PROMPT_TOKEN_BUDGET=6000

# --- Vision (optional, off by default -- needs a local Ollama vision model pulled) ---
VISION__ENABLED=false
VISION__PROVIDER=qwen2-vl-7b
VISION__BASE_URL=http://localhost:11434
VISION__MAX_FIGURES_PER_PAPER=15
VISION__TEMPERATURE=0.1
VISION__MAX_TOKENS=512
VISION__CROP_DPI=300

# --- Embeddings ---
EMBEDDINGS__PROVIDER=bge-large-en-v1.5
EMBEDDINGS__DEVICE=cpu   # set to "cuda" if this machine has an NVIDIA GPU + matching-CUDA torch build

# --- FAISS ---
FAISS__INDEX_PATH=./data/faiss_index
FAISS__TOP_K=5
FAISS__INDEX_TYPE=Flat

# --- Reflection loop ---
REFLECTION__MAX_REVISION_PASSES=1

# --- Ingestion (PeerRead mandatory, arXiv/Semantic Scholar optional) ---
INGESTION__PEERREAD_DATA_PATH=./data/peerread_raw
INGESTION__MAX_PEERREAD_PAPERS=30
INGESTION__ENABLE_ARXIV=false
INGESTION__ENABLE_SEMANTIC_SCHOLAR=false
# Example tailored to a KV-cache/long-context LLM paper -- customize to your actual test paper's topic:
INGESTION__ARXIV_SEARCH_QUERY=abs:"KV cache" AND cat:cs.CL
INGESTION__ARXIV_MAX_RESULTS=20

# --- Live sources (optional; agent-side live query at review time -- see
# RAG_SETTINGS.live_sources.enable_* in core/config/rag_settings.py to
# actually turn queries on, this is just the auth) ---
# Free key from https://www.semanticscholar.org/product/api -- raises the
# unauthenticated shared rate limit to a per-key limit. Leave blank to call
# the public API unauthenticated (works, just more likely to hit 429s).
LIVE_SOURCES__SEMANTIC_SCHOLAR_API_KEY=

LOG_LEVEL=INFO
